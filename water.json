    {
      "parameters": {
        "jsCode": "const data = $json.callback_query?.data || '';\nconst match = data.match(/^WATER_(\\d+)$/);\nif (!match) return [];\nconst drink = Number(match[1]);\nconst chatId = $json.callback_query?.message?.chat?.id;\nconst messageId = $json.callback_query?.message?.message_id;\nconst localNow = new Date(new Date().toLocaleString('en-US', { timeZone: 'Asia/Taipei' }));\nconst yyyy = localNow.getFullYear();\nconst mm = String(localNow.getMonth() + 1).padStart(2, '0');\nconst dd = String(localNow.getDate()).padStart(2, '0');\nconst dateKey = `${yyyy}-${mm}-${dd}`;\nreturn [{ json: { drink, chat_id: chatId, reminder_message_id: messageId, nowIso: new Date().toISOString(), dateKey } }];"
      },
