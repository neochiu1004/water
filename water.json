    {
      "parameters": {
        "jsCode": "const stateRow = $('Get Water State 2').first()?.json ?? {};\nconst dailyRows = $('Get Water Daily Records 2').all().map(i => i.json);\nconst cb = $('Parse Callback').first().json;\n\nconst today = String(cb.dateKey);\nconst isNewDay = String(stateRow.date_key || '') !== today;\n\nlet currentNo = Number(stateRow.no || 0);\nlet stateDailyTotal = Number(stateRow.daily_total || 0);\nif (isNewDay) {\n  currentNo = 0;\n  stateDailyTotal = 0;\n}\n\nconst requestedDrink = Number(cb.drink || 1);\n\n// 債務只扣到 0，但紀錄照實加上使用者按的杯數\nconst debtReduction = Math.min(requestedDrink, Math.max(0, currentNo));\nconst nextNo = Math.max(0, currentNo - debtReduction);\n\nconst todayRow = dailyRows.find(r => String(r.date_key || '') === today) || null;\nconst prevCups = todayRow ? Number(todayRow.cups || 0) : stateDailyTotal;\nconst target = todayRow ? Number(todayRow.target || 16) : 16;\n\n// 這裡改成照實記錄 requestedDrink，不再被 currentNo 限制\nconst loggedDrink = requestedDrink;\nconst nextDailyTotal = prevCups + loggedDrink;\nconst achieved = nextDailyTotal >= target ? 'yes' : 'no';\n\nconst confirmText = `✅ 已記錄喝水 ${loggedDrink} 杯\\n目前補杯數已更新為：${nextNo}\\n今日累計：${nextDailyTotal} / ${target} 杯`;\n\nreturn [{\n  json: {\n    id: stateRow.id || 1,\n    no: nextNo,\n    status: nextNo === 0 ? 'drank' : 'waiting',\n    daily_total: nextDailyTotal,\n    date_key: today,\n    last_drink_at: cb.nowIso,\n    last_message_id: stateRow.last_message_id || cb.reminder_message_id || '',\n    reminder_message_id: cb.reminder_message_id,\n    confirm_text: confirmText,\n    cups: nextDailyTotal,\n    target,\n    achieved\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
