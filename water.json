      "name": "Get Water Daily Records"
    },
    {
      "parameters": {
        "jsCode": "const stateRow = $('Get Water State').first()?.json ?? {};\nconst dailyRows = $('Get Water Daily Records').all().map(i => i.json);\nconst ctx = $('Build Time Context').first().json;\n\nconst today = String(ctx.dateKey);\nconst hour = Number(ctx.hour);\nconst isNewDay = String(stateRow.date_key || '') !== today;\n\nlet no = Number(stateRow.no || 0);\nlet dailyTotal = Number(stateRow.daily_total || 0);\nlet lastMessageId = stateRow.last_message_id ?? '';\n\nif (isNewDay || hour === 6) {\n  no = 0;\n  dailyTotal = 0;\n}\n\nif (hour !== 6) {\n  no += 1;\n}\n\nconst dailyMap = {};\nfor (const row of dailyRows) {\n  if (!row.date_key) continue;\n  dailyMap[String(row.date_key)] = {\n    cups: Number(row.cups || 0),\n    target: Number(row.target || 16),\n    achieved: String(row.achieved || 'no')\n  };\n}\n\nfunction toDate(s) {\n  return new Date(`${s}T00:00:00`);\n}\n\nconst todayDate = toDate(today);\nconst last7 = [];\nfor (let i = 6; i >= 0; i--) {\n  const d = new Date(todayDate);\n  d.setDate(d.getDate() - i);\n  last7.push(d.toISOString().slice(0, 10));\n}\n\nconst todayDaily = dailyMap[today] || { cups: dailyTotal, target: 16, achieved: dailyTotal >= 16 ? 'yes' : 'no' };\nconst todayCups = Number(todayDaily.cups || dailyTotal || 0);\nconst target = Number(todayDaily.target || 16);\n\nlet weekOkDays = 0;\nfor (const key of last7) {\n  const row = dailyMap[key] || { cups: 0, target, achieved: 'no' };\n  const ok = String(row.achieved) === 'yes' || Number(row.cups) >= Number(row.target || target);\n  if (ok) weekOkDays += 1;\n}\n\nconst recent3Marks = [];\nfor (let i = last7.length - 3; i < last7.length; i++) {\n  const key = last7[i];\n  const row = dailyMap[key] || { cups: 0, target, achieved: 'no' };\n  const ok = String(row.achieved) === 'yes' || Number(row.cups) >= Number(row.target || target);\n  recent3Marks.push(ok ? '✅' : '❌');\n}\n\nlet failStreak = 0;\nfor (let i = last7.length - 1; i >= 0; i--) {\n  const key = last7[i];\n  const row = dailyMap[key] || { cups: 0, target, achieved: 'no' };\n  const ok = String(row.achieved) === 'yes' || Number(row.cups) >= Number(row.target || target);\n  if (ok) break;\n  failStreak += 1;\n}\n\nlet level = '💧';\nlet note = '記得補水一下';\nif (no > 5) {\n  level = '🚨🚨🚨';\n  note = '強制提醒：已超過 5 杯，請立刻喝水！';\n} else if (no >= 5) {\n  level = '🚨';\n  note = '已累積很久沒喝水，建議現在先補足';\n} else if (no >= 3) {\n  level = '⚠️';\n  note = '有點久沒喝水了';\n}\n\nlet motivation = '';\nif (todayCups >= target) {\n  motivation = '🏆 今天已達標，繼續保持。';\n} else if (failStreak >= 3) {\n  motivation = `🔥 已連續 ${failStreak} 天未達標，今天至少先補到 ${target} 杯。`;\n} else if (weekOkDays >= 5) {\n  motivation = `🏅 本週已達標 ${weekOkDays}/7 天，再撐一下就很漂亮。`;\n} else {\n  motivation = `再喝 ${Math.max(0, target - todayCups)} 杯，今天就能達標。`;\n}\n\nconst message_text = `${level} 喝水提醒\\n\\n目前應補杯數：${no}\\n今日已喝：${todayCups} / ${target} 杯\\n本週達標：${weekOkDays} / 7 天\\n近三日：${recent3Marks.join(' ')}\\n${note}\\n${motivation}\\n\\n請選擇這次喝了幾杯水`;\n\nreturn [{\n  json: {\n    id: stateRow.id || 1,\n    no,\n    status: no === 0 ? 'drank' : 'waiting',\n    daily_total: todayCups,\n    date_key: today,\n    last_drink_at: stateRow.last_drink_at || '',\n    last_message_id: lastMessageId,\n    target,\n    message_text\n  }\n}];"
      },
